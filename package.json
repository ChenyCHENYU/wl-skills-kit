{
  "name": "@agile-team/wl-skills-kit",
  "version": "2.11.7",
  "description": "AI Skill 模板包 v2.11.7 — 14 条编码规范 + 11 个 AI Skill + 17 个 MCP Tool，一条命令导入 Vue 3 项目（.wl-skills/ 统一隔离架构）",
  "main": "./bin/wl-skills.js",
  "packageManager": "pnpm@11.5.3",
  "bin": {
    "wl-skills": "bin/wl-skills.js"
  },
  "files": [
    "bin/",
    "files/",
    "lib/",
    "mcp/",
    "docs/",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "ai",
    "skills",
    "copilot",
    "vue3",
    "template",
    "codegen",
    "cursor",
    "windsurf",
    "kiro",
    "agents"
  ],
  "author": "JHLC Frontend Team",
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChenyCHENYU/wl-skills-kit.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "standards:init": "pnpm dlx @robot-admin/git-standards init",
    "prepare": "husky",
    "cz": "git-cz",
    "lint": "eslint .",
    "lint:skills": "node scripts/lint-skills.js",
    "test": "vitest run",
    "version:verify": "node scripts/verify-version.js",
    "verify": "pnpm version:verify && pnpm lint && pnpm lint:skills && pnpm test",
    "ci": "pnpm install --frozen-lockfile && pnpm verify",
    "pack:dry": "npm pack --dry-run --ignore-scripts",
    "release:check": "pnpm verify && npm pack --dry-run --ignore-scripts",
    "prepublishOnly": "node scripts/verify-version.js && pnpm lint && node scripts/lint-skills.js && vitest run"
  },
  "optionalDependencies": {
    "@babel/parser": "^7.20.0",
    "@vue/compiler-sfc": "^3.2.0"
  },
  "peerDependencies": {
    "@babel/parser": "^7.20.0",
    "@vue/compiler-sfc": "^3.2.0"
  },
  "peerDependenciesMeta": {
    "@vue/compiler-sfc": {
      "optional": true
    },
    "@babel/parser": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vue/eslint-config-typescript": "^14.7.0",
    "commitizen": "^4.3.1",
    "cz-customizable": "^7.5.4",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "vitest": "^2.1.9"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    }
  },
  "lint-staged": {
    "bin/**/*.js": [
      "eslint --fix --no-cache"
    ],
    "lib/**/*.js": [
      "eslint --fix --no-cache"
    ],
    "scripts/**/*.js": [
      "eslint --fix --no-cache"
    ]
  },
  "dependencies": {
    "write-excel-file": "^4.1.1"
  }
}
