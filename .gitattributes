# 统一行尾符为 LF，消除 Windows 开发者提交噪音
* text=auto eol=lf

# 明确声明文本文件
*.md   text eol=lf
*.js   text eol=lf
*.ts   text eol=lf
*.vue  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.scss text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.sh   text eol=lf

# 二进制文件不做处理
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
